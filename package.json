{
  "name": "amazon-ads-manager",
  "version": "1.0.0",
  "description": "Applicazione per gestire e automatizzare le campagne Amazon Ads",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "ts-node src/test/testAutomations.ts all",
    "test:func1": "ts-node src/test/testAutomations.ts func1",
    "test:func2": "ts-node src/test/testAutomations.ts func2",
    "test:func3": "ts-node src/test/testAutomations.ts func3",
    "test:func4": "ts-node src/test/testAutomations.ts func4",
    "test:func5": "ts-node src/test/testAutomations.ts func5",
    "test:live": "ts-node src/test/testAutomations.ts all --live"
  },
  "keywords": ["amazon", "ads", "advertising", "automation"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "axios": "^1.6.0",
    "pg": "^8.11.3",
    "typeorm": "^0.3.17",
    "winston": "^3.11.0",
    "axios-retry": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
