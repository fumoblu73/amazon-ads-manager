# ================================================
# FILE DI ESEMPIO PER VARIABILI D'AMBIENTE
# ================================================
# Copia questo file in un nuovo file chiamato ".env"
# e inserisci i tuoi valori reali

# ================================================
# SERVER CONFIGURATION
# ================================================

# Porta su cui il server ascolta le richieste
PORT=3000

# Node environment (development, production)
NODE_ENV=development

# ================================================
# DATABASE CONFIGURATION (POSTGRESQL/SUPABASE)
# ================================================

# Configurazione Database PostgreSQL
# OPZIONE 1: Parametri singoli (per sviluppo locale)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=amazon_ads_manager

# OPZIONE 2: Connection String (per Supabase/Production)
# Usa questo invece dei parametri singoli quando sei in produzione
# DATABASE_URL=postgresql://user:password@host:port/database

# Supabase (opzionale, se usi Supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key

# ================================================
# AMAZON ADVERTISING API CREDENTIALS
# ================================================
# Ottieni queste credenziali da: https://advertising.amazon.com/API/docs
# Guida: https://advertising.amazon.com/API/docs/en-us/get-started

# Client ID della tua applicazione Amazon Advertising
AMAZON_CLIENT_ID=your_client_id_here

# Client Secret della tua applicazione (TIENILO SEGRETO!)
AMAZON_CLIENT_SECRET=your_client_secret_here

# Refresh Token (generato dopo l'autorizzazione OAuth)
# Usa lo script get-refresh-token.js per ottenerlo
AMAZON_REFRESH_TOKEN=your_refresh_token_here

# Profile ID del tuo account pubblicitario
# Usa lo script get-profile-id.js per ottenerlo
AMAZON_PROFILE_ID=your_profile_id_here

# Regione API (EU, NA, o FE)
# EU = Europa, NA = Nord America, FE = Far East (Asia)
AMAZON_REGION=EU

# ================================================
# SECURITY TOKENS
# ================================================

# Secret per trigger automazioni (usato da cron-job.org)
# Genera un token sicuro con: openssl rand -hex 32
# Oppure usa: https://www.uuidgenerator.net/
AUTOMATION_SECRET=change-me-in-production

# Token per trigger manuali (admin access)
# Genera un token sicuro con: openssl rand -hex 32
ADMIN_TOKEN=change-me-in-production

# ================================================
# AUTOMATION SETTINGS
# ================================================

# Ogni quanti minuti eseguire i controlli automatici
# NOTA: Su Render Free, NON usare scheduler interno
# Usa invece cron-job.org che chiama l'endpoint /api/automation/trigger
AUTOMATION_INTERVAL_MINUTES=60

# Abilita o disabilita le automazioni (true/false)
# DEPRECATO: Ora le automazioni sono controllate dalla configurazione per campagna
ENABLE_AUTOMATIONS=true

# ================================================
# LOGGING & MONITORING (OPZIONALI)
# ================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Sentry DSN per error tracking (opzionale)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
