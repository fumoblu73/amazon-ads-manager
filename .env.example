# Development configuration with mock data mode
PORT=3000
NODE_ENV=production

# Use mock data for KDP endpoints (no database required)
USE_MOCK_DATA=false

# Security tokens
ADMIN_TOKEN=your-admin-token-here
AUTOMATION_SECRET=your-automation-secret-here

# Amazon Ads API - OAuth Configuration
AMAZON_ADS_CLIENT_ID=your-amazon-client-id
AMAZON_ADS_CLIENT_SECRET=your-amazon-client-secret
AMAZON_ADS_REDIRECT_URI_LOCAL=http://localhost:3000/api/auth/callback
AMAZON_ADS_REDIRECT_URI_PROD=https://your-app-name.onrender.com/api/auth/callback
AMAZON_ADS_SCOPES=profile

# Session Secret (change in production with random string min 32 chars)
SESSION_SECRET=your-session-secret-min-32-chars

# JWT Secret for authentication
JWT_SECRET=your-jwt-secret-min-32-chars

# Frontend URL
FRONTEND_URL=https://your-frontend-url.onrender.com

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.project:password@host.supabase.co:5432/postgres
